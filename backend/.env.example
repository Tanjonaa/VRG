# ============================================================
# VaRyGasy — Variables d'environnement (déploiement o2switch)
# À renseigner dans cPanel → Setup Node.js App → Environment variables
# ============================================================

# ── Base de données (créée via cPanel → MySQL Databases) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=monuser_vrg          # nom complet cPanel : <prefixe>_vrg
DB_USER=monuser_vrguser      # nom complet cPanel : <prefixe>_vrguser
DB_PASSWORD=motdepasse_db

# ── Sécurité ──
# Min. 16 caractères aléatoires — l'app REFUSE de démarrer sans (ou si trop faible).
# Générer : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=remplace_par_une_longue_chaine_aleatoire_min_16_caracteres

# ── CORS (optionnel) — origines autorisées, séparées par des virgules ──
# Défaut : varygasy.net + localhost. À surcharger si autre domaine.
# CORS_ORIGINS=https://varygasy.net,https://www.varygasy.net

# ── Dossier des images uploadées (doit être writable) ──
# Ex : /home/MONUSER/varygasy/uploads
UPLOAD_DIR=/home/MONUSER/varygasy/uploads

# ── Frontend React buildé (dossier dist uploadé) ──
# Ex : /home/MONUSER/varygasy/frontend-dist
FRONTEND_DIST=/home/MONUSER/varygasy/frontend-dist

# ── Port : laissé géré par cPanel/Passenger (ne pas définir) ──
# PORT est injecté automatiquement par l'hébergeur.
